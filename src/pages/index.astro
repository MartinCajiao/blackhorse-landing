<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BlackHorse — Local AI for Professionals</title>
    <meta name="description" content="A powerful local AI assistant that runs entirely on your machine. No cloud, no subscriptions, no data leaving your hands." />
    <link rel="icon" type="image/png" href="/blackhorse-landing/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --bg:      #080808;
        --surface: #111111;
        --surface2:#161616;
        --border:  rgba(255,255,255,0.07);
        --red:     #dc2626;
        --text:    rgba(255,255,255,0.85);
        --muted:   rgba(255,255,255,0.4);
        --faint:   rgba(255,255,255,0.1);
      }
      html { scroll-behavior: smooth; }
      body { font-family:'Inter',sans-serif; background:var(--bg); color:var(--text); line-height:1.6; -webkit-font-smoothing:antialiased; }

      /* ── Nav ── */
      nav {
        position:fixed; top:0; left:0; right:0; z-index:50;
        display:flex; align-items:center; justify-content:space-between;
        padding:0 2rem; height:56px;
        background:rgba(8,8,8,0.88); backdrop-filter:blur(12px);
        border-bottom:1px solid var(--border);
      }
      .nav-logo { display:flex; align-items:center; gap:0.6rem; font-weight:600; font-size:0.95rem; text-decoration:none; color:var(--text); }
      .nav-dot { width:8px; height:8px; border-radius:50%; background:var(--red); box-shadow:0 0 8px rgba(220,38,38,0.6); animation:breathe 3s ease-in-out infinite; }
      @keyframes breathe { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.85)} }
      .nav-links { display:flex; align-items:center; gap:1.5rem; }
      .nav-links a { font-size:0.82rem; color:var(--muted); text-decoration:none; transition:color .2s; }
      .nav-links a:hover { color:var(--text); }
      .btn-nav { font-size:0.82rem; font-weight:600; padding:0.45rem 1rem; border-radius:6px; background:var(--red); color:#fff; text-decoration:none; transition:background .2s; }
      .btn-nav:hover { background:#b91c1c; }

      /* ── Utilities ── */
      .wrap { max-width:1100px; margin:0 auto; padding:5rem 1.5rem; }
      .section-label { font-size:0.72rem; font-family:'JetBrains Mono',monospace; font-weight:500; letter-spacing:0.14em; text-transform:uppercase; color:var(--red); margin-bottom:1rem; }
      .section-title { font-size:clamp(1.8rem,4vw,2.8rem); font-weight:700; letter-spacing:-0.02em; line-height:1.15; margin-bottom:1rem; }
      .section-sub { font-size:1rem; color:var(--muted); max-width:520px; line-height:1.7; }

      /* ── Hero ── */
      .hero {
        min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center;
        text-align:center; padding:6rem 1.5rem 4rem; position:relative; overflow:hidden;
      }
      .hero::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse 70% 55% at 50% 40%, rgba(220,38,38,0.07) 0%, transparent 70%); pointer-events:none; }
      .hero-badge { display:inline-flex; align-items:center; gap:0.5rem; font-size:0.72rem; font-family:'JetBrains Mono',monospace; font-weight:500; letter-spacing:0.12em; text-transform:uppercase; color:rgba(220,38,38,0.8); background:rgba(220,38,38,0.08); border:1px solid rgba(220,38,38,0.2); padding:0.35rem 0.9rem; border-radius:999px; margin-bottom:2rem; }
      .hero h1 { font-size:clamp(2.8rem,7vw,5.5rem); font-weight:700; line-height:1.08; letter-spacing:-0.03em; margin-bottom:1.5rem; }
      .hero h1 span { color:var(--red); }
      .hero p { font-size:clamp(1rem,2vw,1.18rem); color:var(--muted); max-width:560px; margin:0 auto 2.5rem; line-height:1.7; }
      .hero-actions { display:flex; gap:0.9rem; flex-wrap:wrap; justify-content:center; }
      .btn-primary { display:inline-flex; align-items:center; gap:0.5rem; font-size:0.9rem; font-weight:600; padding:0.75rem 1.75rem; border-radius:10px; background:var(--red); color:#fff; text-decoration:none; transition:background .2s,transform .15s; }
      .btn-primary:hover { background:#b91c1c; transform:translateY(-1px); }
      .btn-secondary { display:inline-flex; align-items:center; gap:0.5rem; font-size:0.9rem; font-weight:500; padding:0.75rem 1.75rem; border-radius:10px; background:transparent; border:1px solid var(--faint); color:var(--muted); text-decoration:none; transition:border-color .2s,color .2s,transform .15s; }
      .btn-secondary:hover { border-color:rgba(255,255,255,0.25); color:var(--text); transform:translateY(-1px); }
      .hero-meta { margin-top:3rem; display:flex; gap:1.5rem; flex-wrap:wrap; justify-content:center; }
      .hero-meta span { font-size:0.78rem; font-family:'JetBrains Mono',monospace; color:rgba(255,255,255,0.22); letter-spacing:0.05em; }

      /* ── Features ── */
      .features-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:1px; border:1px solid var(--border); border-radius:16px; overflow:hidden; margin-top:3.5rem; background:var(--border); }
      .feature-card { background:var(--surface); padding:2rem; transition:background .2s; }
      .feature-card:hover { background:var(--surface2); }
      .feature-icon { font-size:1.6rem; margin-bottom:1rem; }
      .feature-card h3 { font-size:1rem; font-weight:600; margin-bottom:0.5rem; }
      .feature-card p { font-size:0.88rem; color:var(--muted); line-height:1.65; }

      /* ── Privacy ── */
      .privacy-block { background:var(--surface); border:1px solid var(--border); border-radius:16px; padding:3rem; display:grid; grid-template-columns:1fr 1fr; gap:3rem; align-items:center; margin-top:5rem; }
      .privacy-block h2 { font-size:clamp(1.6rem,3vw,2.2rem); font-weight:700; letter-spacing:-0.02em; line-height:1.2; margin-bottom:1rem; }
      .privacy-block p { font-size:0.92rem; color:var(--muted); line-height:1.7; }
      .privacy-pills { display:flex; flex-direction:column; gap:0.75rem; }
      .pill { display:flex; align-items:center; gap:0.75rem; background:rgba(255,255,255,0.03); border:1px solid var(--border); border-radius:10px; padding:0.85rem 1.1rem; font-size:0.85rem; }
      .pill-dot { width:6px; height:6px; border-radius:50%; background:var(--red); flex-shrink:0; }

      /* ── Internet disclosure ── */
      .disclosure { background:rgba(220,38,38,0.05); border:1px solid rgba(220,38,38,0.15); border-radius:14px; padding:1.75rem 2rem; margin-top:2rem; display:flex; gap:1.25rem; align-items:flex-start; }
      .disclosure-icon { font-size:1.2rem; flex-shrink:0; margin-top:2px; }
      .disclosure h4 { font-size:0.9rem; font-weight:600; margin-bottom:0.35rem; }
      .disclosure p { font-size:0.85rem; color:var(--muted); line-height:1.65; }

      /* ── Tech ── */
      .tech-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:1px; border:1px solid var(--border); border-radius:16px; overflow:hidden; margin-top:3rem; background:var(--border); }
      .tech-card { background:var(--surface); padding:1.75rem 2rem; transition:background .2s; }
      .tech-card:hover { background:var(--surface2); }
      .tech-tag { display:inline-block; font-size:0.68rem; font-family:'JetBrains Mono',monospace; font-weight:500; letter-spacing:0.1em; text-transform:uppercase; color:var(--red); background:rgba(220,38,38,0.08); border:1px solid rgba(220,38,38,0.18); padding:0.2rem 0.6rem; border-radius:4px; margin-bottom:0.75rem; }
      .tech-card h3 { font-size:1.05rem; font-weight:600; margin-bottom:0.5rem; }
      .tech-card p { font-size:0.86rem; color:var(--muted); line-height:1.65; }
      .tech-footer { display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:0; border:1px solid var(--border); border-radius:12px; overflow:hidden; margin-top:1px; background:var(--border); }
      .tech-footer-item { background:rgba(255,255,255,0.02); padding:1rem 1.5rem; display:flex; flex-direction:column; gap:0.3rem; }
      .tf-label { font-size:0.68rem; font-family:'JetBrains Mono',monospace; letter-spacing:0.1em; text-transform:uppercase; color:rgba(255,255,255,0.25); }
      .tf-val { font-size:0.82rem; color:var(--muted); }

      /* ── Roadmap ── */
      .roadmap-list { margin-top:3rem; display:flex; flex-direction:column; gap:0; border:1px solid var(--border); border-radius:16px; overflow:hidden; }
      .roadmap-item { display:flex; align-items:center; gap:1.5rem; padding:1.1rem 1.5rem; background:var(--surface); border-bottom:1px solid var(--border); transition:background .2s; }
      .roadmap-item:last-child { border-bottom:none; }
      .roadmap-item:hover { background:var(--surface2); }
      .roadmap-label { font-size:0.72rem; font-family:'JetBrains Mono',monospace; font-weight:500; letter-spacing:0.1em; text-transform:uppercase; color:var(--red); min-width:60px; }
      .roadmap-item span:last-child { font-size:0.9rem; color:var(--muted); }

      /* ── Pricing ── */
      .pricing-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:1.5rem; margin-top:3rem; }
      .pricing-card { background:var(--surface); border:1px solid var(--border); border-radius:16px; padding:2rem; display:flex; flex-direction:column; gap:1rem; position:relative; transition:border-color .2s; }
      .pricing-card:hover { border-color:rgba(255,255,255,0.15); }
      .pricing-card.highlight { border-color:rgba(220,38,38,0.4); background:rgba(220,38,38,0.04); }
      .pricing-card.highlight::before { content:'Best value'; position:absolute; top:-12px; left:50%; transform:translateX(-50%); font-size:0.68rem; font-family:'JetBrains Mono',monospace; font-weight:500; letter-spacing:0.1em; text-transform:uppercase; color:var(--red); background:var(--bg); border:1px solid rgba(220,38,38,0.3); padding:0.25rem 0.75rem; border-radius:999px; white-space:nowrap; }
      .pricing-name { font-size:0.8rem; font-family:'JetBrains Mono',monospace; letter-spacing:0.08em; text-transform:uppercase; color:var(--muted); }
      .pricing-price { display:flex; align-items:baseline; gap:0.4rem; }
      .pricing-price .amount { font-size:3rem; font-weight:700; letter-spacing:-0.03em; }
      .pricing-price .period { font-size:0.85rem; color:var(--muted); }
      .pricing-desc { font-size:0.88rem; color:var(--muted); line-height:1.6; }
      .pricing-perks { display:flex; flex-direction:column; gap:0.55rem; margin-top:0.5rem; }
      .perk { display:flex; align-items:flex-start; gap:0.6rem; font-size:0.85rem; }
      .perk-check { color:var(--red); flex-shrink:0; margin-top:2px; }
      .pricing-cta { margin-top:auto; padding-top:1.5rem; }
      .btn-buy { display:block; text-align:center; padding:0.8rem 1.5rem; border-radius:10px; font-weight:600; font-size:0.9rem; text-decoration:none; transition:all .2s; }
      .btn-buy-primary { background:var(--red); color:#fff; }
      .btn-buy-primary:hover { background:#b91c1c; }
      .btn-buy-ghost { background:transparent; border:1px solid var(--faint); color:var(--muted); }
      .btn-buy-ghost:hover { border-color:rgba(255,255,255,0.25); color:var(--text); }

      /* ── Compliance note ── */
      .compliance { background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:2rem; margin-top:3rem; }
      .compliance h4 { font-size:0.9rem; font-weight:600; margin-bottom:0.75rem; }
      .compliance p { font-size:0.85rem; color:var(--muted); line-height:1.7; }
      .compliance p + p { margin-top:0.75rem; }

      /* ── Download ── */
      .download-section { text-align:center; padding:5rem 1.5rem; position:relative; overflow:hidden; }
      .download-section::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse 60% 50% at 50% 100%, rgba(220,38,38,0.05) 0%, transparent 70%); pointer-events:none; }
      .download-cards { display:flex; gap:1rem; flex-wrap:wrap; justify-content:center; margin-top:2.5rem; }
      .download-card { background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:1.5rem 2rem; min-width:200px; text-align:left; text-decoration:none; color:var(--text); transition:border-color .2s,transform .15s; display:flex; flex-direction:column; gap:0.4rem; }
      .download-card:hover { border-color:rgba(220,38,38,0.35); transform:translateY(-2px); }
      .dc-label { font-size:0.7rem; font-family:'JetBrains Mono',monospace; letter-spacing:0.1em; text-transform:uppercase; color:var(--red); }
      .dc-title { font-size:1rem; font-weight:600; }
      .dc-sub { font-size:0.78rem; color:var(--muted); }
      .download-note { font-size:0.78rem; color:rgba(255,255,255,0.18); font-family:'JetBrains Mono',monospace; margin-top:1.5rem; }

      /* ── Footer ── */
      footer { border-top:1px solid var(--border); padding:2rem 1.5rem; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem; max-width:1100px; margin:0 auto; font-size:0.8rem; color:rgba(255,255,255,0.2); }
      footer a { color:rgba(255,255,255,0.3); text-decoration:none; }
      footer a:hover { color:rgba(255,255,255,0.6); }

      @media (max-width:640px) {
        .nav-links { display:none; }
        .privacy-block { grid-template-columns:1fr; gap:2rem; }
      }
    </style>
  </head>
  <body>

    <!-- Nav -->
    <nav>
      <a href="/" class="nav-logo">
        <span class="nav-dot"></span>
        BlackHorse
      </a>
      <div class="nav-links">
        <a href="#features">Features</a>
        <a href="#tech">Tech</a>
        <a href="#roadmap">Roadmap</a>
        <a href="#pricing">Pricing</a>
        <a href="#download">Download</a>
        <a href="https://patrimony.gumroad.com/l/kszhx" target="_blank" rel="noopener" class="btn-nav">Get it free</a>
      </div>
    </nav>

    <!-- Hero -->
    <div class="hero">
      <div class="hero-badge">&#x25CF; v1.0 &mdash; Windows &middot; Vulkan &middot; CUDA</div>
      <h1>AI that runs<br /><span>on your machine.</span></h1>
      <p>
        BlackHorse is a local AI assistant built for professionals.
        Chat, analyze code, review documents, and automate emails &mdash;
        with zero cloud dependency and zero data leaving your hands.
      </p>
      <div class="hero-actions">
        <a href="https://patrimony.gumroad.com/l/kszhx" target="_blank" rel="noopener" class="btn-primary">
          Download free demo
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </a>
        <a href="#pricing" class="btn-secondary">See pricing</a>
      </div>
      <div class="hero-meta">
        <span>No subscription</span>
        <span>&middot;</span>
        <span>No account</span>
        <span>&middot;</span>
        <span>No internet required</span>
        <span>&middot;</span>
        <span>Bring your own model</span>
      </div>
    </div>

    <!-- Features -->
    <div class="wrap" id="features">
      <div class="section-label">Capabilities</div>
      <h2 class="section-title">Everything you need,<br />nothing you don't.</h2>
      <p class="section-sub">Built on llama.cpp with native GPU acceleration. Fast, lean, and entirely under your control.</p>
      <div class="features-grid">
        {features.map((f) => (
          <div class="feature-card">
            <div class="feature-icon">{f.icon}</div>
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>

      <!-- Privacy -->
      <div class="privacy-block" id="privacy">
        <div>
          <div class="section-label">Transparency</div>
          <h2>Your data stays<br />on your machine.</h2>
          <p style="margin-top:1rem">
            BlackHorse makes no network connections during normal operation.
            Conversations, documents, and code are stored in a local SQLite database on your drive.
            No analytics, no telemetry, no DRM pinging a license server.
          </p>
          <div class="disclosure">
            <div class="disclosure-icon">📡</div>
            <div>
              <h4>One exception: Email Automation</h4>
              <p>
                The email automation feature connects to your SMTP server or SendGrid API to send emails on your behalf.
                That is the only outbound connection BlackHorse ever makes &mdash; and only when you explicitly trigger a send.
                No other feature touches the internet.
              </p>
            </div>
          </div>
        </div>
        <div class="privacy-pills">
          <div class="pill"><div class="pill-dot"></div>No API keys required for inference</div>
          <div class="pill"><div class="pill-dot"></div>No telemetry or usage tracking</div>
          <div class="pill"><div class="pill-dot"></div>No account or login needed</div>
          <div class="pill"><div class="pill-dot"></div>No DRM — no license server calls</div>
          <div class="pill"><div class="pill-dot"></div>Works fully offline after setup</div>
          <div class="pill"><div class="pill-dot"></div>Local SQLite — you own your history</div>
          <div class="pill"><div class="pill-dot"></div>Open model format (GGUF)</div>
        </div>
      </div>
    </div>

    <!-- Under the hood -->
    <div class="wrap" id="tech" style="padding-top:0">
      <div class="section-label">Under the hood</div>
      <h2 class="section-title">Not a wrapper.<br />A native stack.</h2>
      <p class="section-sub">
        BlackHorse is built from scratch in Rust &mdash; not Electron, not Python, not a thin shell around an existing tool.
        Every component was chosen for performance, safety, and zero unnecessary dependencies.
      </p>

      <div class="tech-grid">
        <div class="tech-card">
          <div class="tech-tag">Inference</div>
          <h3>llama.cpp</h3>
          <p>
            The de-facto standard for local LLM inference. Pure C++ with GGUF model support, batched decoding,
            KV cache reuse, and hardware-specific paths for AVX2, AVX-512, Vulkan, and CUDA.
            BlackHorse links against it natively &mdash; no subprocess spawning, no IPC overhead.
          </p>
        </div>
        <div class="tech-card">
          <div class="tech-tag">Backend</div>
          <h3>Rust + Axum</h3>
          <p>
            The entire API server is written in Rust. Memory-safe by design &mdash; no null pointer dereferences,
            no buffer overflows, no use-after-free. Axum provides async HTTP with zero-cost abstractions.
            The binary ships as a single self-contained executable with no runtime dependencies.
          </p>
        </div>
        <div class="tech-card">
          <div class="tech-tag">GPU</div>
          <h3>Vulkan &amp; CUDA</h3>
          <p>
            Vulkan build works on AMD, Intel, and NVIDIA &mdash; any GPU with Vulkan 1.2 support.
            CUDA build targets NVIDIA exclusively for maximum throughput on RTX/GTX hardware.
            GPU layers are configurable: offload as many transformer layers as VRAM allows,
            fall back to CPU for the rest. No all-or-nothing requirement.
          </p>
        </div>
        <div class="tech-card">
          <div class="tech-tag">Embeddings</div>
          <h3>fastembed-rs</h3>
          <p>
            Document analysis uses a local embedding model (multilingual-e5-small) via fastembed-rs,
            a Rust-native embedding library. Downloaded once on first use, then cached locally.
            No external embedding API, no tokens leaving the machine.
          </p>
        </div>
        <div class="tech-card">
          <div class="tech-tag">Storage</div>
          <h3>SQLite via sqlx</h3>
          <p>
            All conversation history, sessions, and configuration are stored in a single SQLite file
            on your machine. sqlx provides compile-time verified queries &mdash; no SQL injection,
            no runtime schema surprises. Migrations run automatically on startup.
          </p>
        </div>
        <div class="tech-card">
          <div class="tech-tag">Frontend</div>
          <h3>Neutralino + React</h3>
          <p>
            The desktop UI uses Neutralino.js &mdash; a lightweight alternative to Electron that adds
            roughly 1.7 MB of overhead instead of 100+ MB. The React frontend communicates with the
            Rust backend over a local HTTP + SSE channel for real-time token streaming.
          </p>
        </div>
      </div>

      <div class="tech-footer">
        <div class="tech-footer-item">
          <span class="tf-label">Model format</span>
          <span class="tf-val">GGUF — any quantization (Q2 to Q8, F16)</span>
        </div>
        <div class="tech-footer-item">
